{
  "name": "voip-electron",
  "version": "1.0.0",
  "description": "VoIP desktop app for gaming with friends",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev":   "electron . --inspect",
    "pack":  "electron-builder --dir",
    "dist":  "electron-builder"
  },
  "dependencies": {
    "socket.io-client": "^4.7.5"
  },
  "devDependencies": {
    "electron":         "^30.0.0",
    "electron-builder": "^24.13.0"
  },
  "build": {
    "appId":       "com.voip.gaming",
    "productName": "VoIP",
    "directories": { "output": "dist" },
    "win": {
      "target": ["nsis"],
      "icon":   "assets/icon.ico"
    },
    "mac": {
      "target": ["dmg"],
      "icon":   "assets/icon.icns"
    },
    "linux": {
      "target": ["AppImage"],
      "icon":   "assets/icon.png"
    }
  }
}
